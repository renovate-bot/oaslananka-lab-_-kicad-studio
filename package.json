        "category": "KiCad AI",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "kicadstudio.testAiConnection",
        "title": "KiCad: Test AI Connection",
        "category": "KiCad AI",
        "icon": "$(pulse)"
      },
      {
        "command": "kicadstudio.searchLibrarySymbol",
        "title": "KiCad: Search Symbol Library",
        "category": "KiCad Library",
        "icon": "$(search)"
      },
      {
        "command": "kicadstudio.searchLibraryFootprint",
        "title": "KiCad: Search Footprint Library",
        "category": "KiCad Library",
        "icon": "$(circuit-board)"
      },
      {
        "command": "kicadstudio.reindexLibraries",
        "title": "KiCad: Reindex Libraries",
        "category": "KiCad Library",
        "icon": "$(refresh)"
      },
      {
        "command": "kicadstudio.refreshProjectTree",
        "title": "KiCad: Refresh Project Tree",
        "category": "KiCad",
        "icon": "$(refresh)"
      },
      {
        "command": "kicadstudio.saveExportPreset",
        "title": "KiCad: Save Export Preset",
        "category": "KiCad"
      },
      {
        "command": "kicadstudio.runExportPreset",
        "title": "KiCad: Run Export Preset",
        "category": "KiCad"
      },
      {
        "command": "kicadstudio.setOctopartApiKey",
