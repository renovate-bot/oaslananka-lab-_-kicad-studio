      },
      {
        "command": "kicadstudio.variant.diffBom",
        "title": "KiCad: Compare Variant BOMs",
        "category": "KiCad Variants"
      },
      {
        "command": "kicadstudio.variant.refresh",
        "title": "KiCad: Refresh Variants",
        "category": "KiCad Variants",
        "icon": "$(refresh)"
      },
      {
        "command": "kicadstudio.drcRule.reveal",
        "title": "KiCad: Reveal DRC Rule",
        "category": "KiCad DRC"
      },
      {
        "command": "kicadstudio.drcRule.addWithMcp",
        "title": "KiCad: Add DRC Rule with MCP",
        "category": "KiCad DRC",
        "icon": "$(add)"
      },
      {
        "command": "kicadstudio.exportViewerSvg",
        "title": "KiCad: Export Viewer SVG",
        "category": "KiCad Viewer"
      },
      {
        "command": "kicadstudio.importPads",
        "title": "KiCad: Import PADS Board",
