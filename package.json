      {
        "command": "kicadstudio.importFabmaster",
        "title": "KiCad: Import Fabmaster Board",
        "category": "KiCad Import"
      },
      {
        "command": "kicadstudio.importPcad",
        "title": "KiCad: Import P-CAD Board",
        "category": "KiCad Import"
      },
      {
        "command": "kicadstudio.importSolidworks",
        "title": "KiCad: Import SolidWorks PCB",
        "category": "KiCad Import"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .kicad_sch",
          "command": "kicadstudio.openSchematic",
          "group": "navigation"
        },
        {
          "when": "resourceExtname == .kicad_pcb",
          "command": "kicadstudio.openPCB",
          "group": "navigation"
        },
        {
          "when": "resourceExtname =~ /\\.kicad_(sch|pcb|sym|mod|pro)/",
          "command": "kicadstudio.openInKiCad",
          "group": "navigation"
        },
        {
          "when": "resourceExtname == .kicad_jobset",
          "command": "kicadstudio.runJobset",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "when": "activeCustomEditorId == kicadstudio.schematicViewer || activeCustomEditorId == kicadstudio.pcbViewer",
          "command": "kicadstudio.openInKiCad",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "when": "view == kicadstudio.projectTree",
          "command": "kicadstudio.refreshProjectTree",
          "group": "navigation"
        },
        {
          "when": "view == kicadstudio.variants",
          "command": "kicadstudio.variant.refresh",
          "group": "navigation"
        },
        {
          "when": "view == kicadstudio.variants",
          "command": "kicadstudio.variant.create",
          "group": "navigation"
        },
        {
          "when": "view == kicadstudio.fixQueue",
          "command": "kicadstudio.refreshFixQueue",
          "group": "navigation"
        },
        {
          "when": "view == kicadstudio.drcRules",
          "command": "kicadstudio.drcRule.addWithMcp",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "kicadstudio.exportGerbers",
          "when": "kicadstudio.pcbOpen"
        },
        {
          "command": "kicadstudio.exportIPC2581",
          "when": "kicadstudio.pcbOpen"
        },
        {
          "command": "kicadstudio.export3DGLB",
          "when": "kicadstudio.pcbOpen"
        },
        {
          "command": "kicadstudio.export3DBREP",
          "when": "kicadstudio.pcbOpen"
        },
        {
          "command": "kicadstudio.export3DPLY",
          "when": "kicadstudio.pcbOpen"
        },
        {
          "command": "kicadstudio.export3DPdf",
          "when": "kicadstudio.pcbOpen && kicadstudio.kicad10Plus"
        },
        {
          "command": "kicadstudio.exportGenCAD",
          "when": "kicadstudio.pcbOpen"
        },
        {
          "command": "kicadstudio.exportIPCD356",
          "when": "kicadstudio.pcbOpen"
        },
        {
          "command": "kicadstudio.exportDXF"
        },
        {
          "command": "kicadstudio.exportPickAndPlace",
          "when": "kicadstudio.pcbOpen"
        },
        {
          "command": "kicadstudio.exportManufacturingPackage",
          "when": "kicadstudio.pcbOpen"
        },
        {
          "command": "kicadstudio.exportFootprintSVG"
        },
        {
          "command": "kicadstudio.exportSymbolSVG"
        },
        {
          "command": "kicadstudio.runJobset"
        },
        {
          "command": "kicadstudio.runDRC",
          "when": "kicadstudio.pcbOpen"
        },
        {
          "command": "kicadstudio.runERC",
          "when": "kicadstudio.schematicOpen"
        },
        {
          "command": "kicadstudio.exportPDF",
          "when": "kicadstudio.schematicOpen"
        },
        {
          "command": "kicadstudio.exportBOMCSV",
          "when": "kicadstudio.schematicOpen"
        },
        {
          "command": "kicadstudio.aiAnalyzeError",
          "when": "kicadstudio.aiEnabled"
        },
        {
          "command": "kicadstudio.aiProactiveDRC",
          "when": "kicadstudio.aiEnabled && kicadstudio.pcbOpen"
        },
        {
          "command": "kicadstudio.aiExplainCircuit",
          "when": "kicadstudio.aiEnabled"
        },
        {
          "command": "kicadstudio.openAiChat",
          "when": "kicadstudio.aiEnabled"
        },
        {
          "command": "kicadstudio.setupMcpIntegration"
        },
        {
          "command": "kicadstudio.showStoredSecrets"
        },
        {
          "command": "kicadstudio.manageChatProvider"
        },
        {
          "command": "kicadstudio.openDesignIntent",
          "when": "kicadstudio.mcpConnected"
        },
        {
          "command": "kicadstudio.variant.create",
          "when": "kicadstudio.kicad10Plus"
        },
        {
          "command": "kicadstudio.variant.setActive",
          "when": "kicadstudio.hasVariants"
        },
        {
          "command": "kicadstudio.variant.diffBom",
          "when": "kicadstudio.hasVariants"
        },
        {
          "command": "kicadstudio.testAiConnection",
          "when": "kicadstudio.aiEnabled"
        },
        {
          "command": "kicadstudio.searchLibrarySymbol"
        },
        {
          "command": "kicadstudio.searchLibraryFootprint"
        },
        {
          "command": "kicadstudio.reindexLibraries"
        },
        {
          "command": "kicadstudio.showStatusMenu"
        },
        {
          "command": "kicadstudio.importPads"
        },
        {
          "command": "kicadstudio.importAltium"
        },
        {
          "command": "kicadstudio.importEagle"
        }
      ]
    },
    "keybindings": [
      {
        "command": "kicadstudio.runDRC",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "kicadstudio.pcbOpen"
      },
      {
        "command": "kicadstudio.runERC",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "kicadstudio.schematicOpen"
      },
      {
        "command": "kicadstudio.exportGerbers",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "kicadstudio.pcbOpen"
      },
      {
        "command": "kicadstudio.searchLibrarySymbol",
        "key": "ctrl+shift+k ctrl+shift+s",
        "mac": "cmd+shift+k cmd+shift+s"
      },
      {
        "command": "kicadstudio.searchLibraryFootprint",
        "key": "ctrl+shift+k ctrl+shift+f",
        "mac": "cmd+shift+k cmd+shift+f"
      }
    ],
    "configuration": {
      "title": "KiCad Studio",
      "properties": {
        "kicadstudio.kicadCliPath": {
          "type": "string",
          "default": "",
          "description": "Path to kicad-cli executable. Leave empty for auto-detection."
        },
        "kicadstudio.kicadPath": {
          "type": "string",
          "default": "",
          "description": "Path to KiCad installation directory (used to open files in KiCad)."
        },
        "kicadstudio.defaultOutputDir": {
          "type": "string",
          "default": "fab",
          "description": "Default output directory for exports (relative to project root)."
        },
        "kicadstudio.gerber.precision": {
          "type": "number",
          "default": 6,
          "enum": [
            5,
            6
          ],
          "description": "Gerber file precision (number of digits)."
        },
        "kicadstudio.gerber.useProtelExtension": {
          "type": "boolean",
          "default": false,
          "description": "Use Protel file extensions for Gerber files."
        },
        "kicadstudio.ipc2581.version": {
          "type": "string",
          "default": "C",
          "enum": [
            "B",
            "C"
          ],
          "description": "IPC-2581 standard version."
        },
        "kicadstudio.ipc2581.units": {
          "type": "string",
          "default": "mm",
          "enum": [
            "mm",
            "in"
          ],
          "description": "Units for IPC-2581 export."
        },
        "kicadstudio.bom.groupIdentical": {
          "type": "boolean",
          "default": true,
          "description": "Group identical components in BOM."
        },
        "kicadstudio.bom.fields": {
          "type": "array",
          "default": [
            "Reference",
            "Value",
            "Footprint",
            "Quantity",
            "MPN",
            "Manufacturer",
            "Description"
          ],
          "description": "BOM fields to include and their order."
        },
        "kicadstudio.cli.defineVars": {
          "type": "object",
          "default": {},
          "description": "Optional KiCad CLI --define-var values that are passed to compatible kicad-cli commands."
        },
        "kicadstudio.viewer.theme": {
          "type": "string",
          "default": "dark",
          "enum": [
            "dark",
            "light",
            "kicad"
          ],
          "description": "Color theme for schematic and PCB viewers."
        },
        "kicadstudio.viewer.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh viewer when file is saved."
        },
        "kicadstudio.viewer.largeFileThresholdBytes": {
          "type": "number",
          "default": 10485760,
          "minimum": 1,
          "description": "Maximum file size for fully interactive embedded viewing before KiCad Studio falls back to metadata-only mode."
        },
        "kicadstudio.viewer.syncThemeWithVscode": {
          "type": "boolean",
          "default": true,
          "description": "Automatically sync viewer colors with the active VS Code theme."
        },
        "kicadstudio.viewer.enableLayerPanel": {
          "type": "boolean",
          "default": true,
          "description": "Show layer visibility controls when PCB metadata is available."
        },
        "kicadstudio.viewer.enableSnapshotExport": {
          "type": "boolean",
          "default": true,
          "description": "Enable PNG and SVG export actions inside the embedded viewer."
        },
        "kicadstudio.componentSearch.enableLCSC": {
          "type": "boolean",
          "default": true,
          "description": "Enable LCSC component search."
        },
        "kicadstudio.ai.provider": {
          "type": "string",
          "default": "none",
          "enum": [
            "none",
            "claude",
            "openai",
            "copilot",
            "gemini"
          ],
          "description": "AI provider for circuit analysis and error explanation."
        },
        "kicadstudio.ai.model": {
          "type": "string",
          "default": "",
          "description": "Optional AI model override. Leave empty to use the provider default: claude-sonnet-4-6 for Claude or gpt-5.4 for OpenAI."
        },
        "kicadstudio.ai.openaiApiMode": {
          "type": "string",
          "default": "responses",
          "enum": [
            "responses",
            "chat-completions"
          ],
          "description": "OpenAI API mode. Responses is the default for new work; Chat Completions is retained for compatibility."
        },
        "kicadstudio.ai.language": {
          "type": "string",
          "default": "en",
          "enum": [
            "en",
            "tr",
            "de",
            "zh-CN",
            "ja",
            "fr",
            "es",
            "ko",
            "pt-BR"
          ],
          "description": "Language for AI-generated answers. Extension UI language follows VS Code locale packs."
        },
        "kicadstudio.ai.allowTools": {
          "type": "boolean",
          "default": true,
          "description": "Allow KiCad Studio to register language-model tools when the host VS Code build supports them."
        },
        "kicadstudio.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "KiCad Studio log verbosity"
        },
        "kicadstudio.drc.autoRunOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run DRC when PCB file is saved."
        },
        "kicadstudio.erc.autoRunOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run ERC when schematic file is saved."
        },
        "kicadstudio.mcp.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect kicad-mcp-pro and offer to create .vscode/mcp.json."
        },
        "kicadstudio.mcp.endpoint": {
          "type": "string",
          "default": "http://127.0.0.1:27185",
          "description": "kicad-mcp-pro HTTP endpoint when the server is running in HTTP mode."
        },
        "kicadstudio.mcp.allowLegacySse": {
          "type": "boolean",
          "default": false,
          "description": "Allow a best-effort fallback to the legacy /sse MCP transport when Streamable HTTP is unavailable."
        },
        "kicadstudio.mcp.pushContext": {
          "type": "boolean",
          "default": true,
          "description": "Push active file, DRC summary, and lasso selection context to kicad-mcp-pro."
        },
        "kicadstudio.exportPresets": {
          "type": "array",
          "default": [],
          "description": "Saved export presets managed by the extension."
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "kicad",
        "required": [
          "task",
          "file"
        ],
        "properties": {
          "task": {
            "type": "string",
            "description": "KiCad task type"
          },
          "file": {
            "type": "string",
            "description": "Target .kicad_pcb or .kicad_sch file"
          },
          "outputDir": {
            "type": "string",
            "description": "Output directory"
          }
        }
      }
    ],
    "snippets": [
      {
        "language": "kicad-schematic",
        "path": "./snippets/kicad.code-snippets"
      },
      {
        "language": "kicad-pcb",
        "path": "./snippets/kicad.code-snippets"
      }
    ],
    "walkthroughs": [
      {
        "id": "kicadstudio.gettingStarted",
        "title": "Getting Started with KiCad Studio",
        "description": "Set up KiCad Studio for your first project.",
        "steps": [
          {
            "id": "kicadstudio.step.detectCli",
            "title": "Detect kicad-cli",
            "description": "KiCad Studio uses kicad-cli for exports and checks. [Detect automatically](command:kicadstudio.detectCli)",
            "media": {
              "altText": "kicad-cli detection",
              "image": "assets/screenshots/schematic-viewer.png"
            },
            "completionEvents": [
              "onCommand:kicadstudio.detectCli"
            ]
          },
          {
            "id": "kicadstudio.step.openProject",
            "title": "Open a KiCad Project",
            "description": "Open a folder containing a .kicad_pro file. [Open folder](command:workbench.action.files.openFolder)",
            "media": {
              "altText": "project tree",
              "image": "assets/screenshots/schematic-viewer.png"
            },
            "completionEvents": [
              "onContext:kicadstudio.hasProject"
            ]
          },
          {
            "id": "kicadstudio.step.viewer",
            "title": "View your Schematic",
            "description": "Click any .kicad_sch file to open the interactive viewer.",
            "media": {
              "altText": "schematic viewer",
              "image": "assets/screenshots/schematic-viewer.png"
            },
            "completionEvents": [
              "onContext:kicadstudio.schematicOpen"
            ]
          },
          {
            "id": "kicadstudio.step.variants",
            "title": "Browse KiCad 10 Variants",
            "description": "Use the Variants sidebar to create, activate, and compare design variants in KiCad 10 projects.",
            "media": {
              "altText": "variants view",
              "image": "assets/screenshots/schematic-viewer.png"
            },
            "completionEvents": [
              "onCommand:kicadstudio.variant.create"
            ]
          },
          {
            "id": "kicadstudio.step.mcp",
            "title": "Connect kicad-mcp-pro",
            "description": "Bootstrap optional MCP integration to unlock fix queues, design intent forms, and tool-backed AI workflows. [Setup MCP](command:kicadstudio.setupMcpIntegration)",
            "media": {
              "altText": "mcp setup",
              "image": "assets/screenshots/ai-assistant.png"
            },
            "completionEvents": [
              "onCommand:kicadstudio.setupMcpIntegration"
            ]
          },
          {
            "id": "kicadstudio.step.ai",
            "title": "Analyze DRC with AI",
            "description": "Run DRC, then ask the AI chat to summarize and prioritize the findings.",
            "media": {
              "altText": "ai assistant",
              "image": "assets/screenshots/ai-assistant.png"
            },
            "completionEvents": [
              "onCommand:kicadstudio.openAiChat"
            ]
          },
          {
            "id": "kicadstudio.step.exports",
            "title": "Create Manufacturing Outputs",
            "description": "Export fabrication packages, 3D assets, or KiCad 10 3D PDF files from the Command Palette.",
            "media": {
              "altText": "pcb viewer",
              "image": "assets/screenshots/pcb-viewer.png"
            },
            "completionEvents": [
              "onCommand:kicadstudio.exportManufacturingPackage"
            ]
          }
        ]
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "kicadstudio.mcpServer",
        "label": "KiCad MCP Pro (bundled)"
      }
    ],
    "languageModelTools": [
      {
        "name": "kicadstudio_runDrc",
        "tags": [
          "kicad",
          "drc",
          "pcb"
        ],
        "toolReferenceName": "runDrc",
        "displayName": "Run KiCad DRC",
        "userDescription": "Run KiCad DRC for the current or specified board.",
        "modelDescription": "Runs KiCad DRC on a .kicad_pcb file and returns a diagnostic summary plus machine-readable diagnostics. Use this when the user asks to check PCB design-rule violations.",
        "canBeReferencedInPrompt": true,
        "icon": "$(beaker)",
        "when": "kicadstudio.hasProject",
        "inputSchema": {
          "type": "object",
          "properties": {
            "pcbPath": {
              "type": "string",
              "description": "Optional absolute path to the .kicad_pcb file. When omitted, KiCad Studio uses the active board or the first board in the workspace."
            }
          }
        }
      },
      {
        "name": "kicadstudio_runErc",
        "tags": [
          "kicad",
          "erc",
          "schematic"
        ],
        "toolReferenceName": "runErc",
        "displayName": "Run KiCad ERC",
        "userDescription": "Run KiCad ERC for the current or specified schematic.",
        "modelDescription": "Runs KiCad ERC on a .kicad_sch file and returns a diagnostic summary plus machine-readable diagnostics. Use this when the user asks to check schematic electrical-rule violations.",
        "canBeReferencedInPrompt": true,
        "icon": "$(check-all)",
        "when": "kicadstudio.hasProject",
        "inputSchema": {
          "type": "object",
          "properties": {
            "schPath": {
              "type": "string",
              "description": "Optional absolute path to the .kicad_sch file. When omitted, KiCad Studio uses the active schematic or the first schematic in the workspace."
            }
          }
        }
      },
      {
        "name": "kicadstudio_exportGerbers",
        "tags": [
          "kicad",
          "gerber",
          "manufacturing"
        ],
        "toolReferenceName": "exportGerbers",
        "displayName": "Export KiCad Gerbers",
        "userDescription": "Export Gerber fabrication files for the current or specified PCB.",
        "modelDescription": "Exports Gerber fabrication files for a KiCad board into the configured KiCad Studio output directory. Use this only when the user explicitly wants manufacturing files created.",
        "canBeReferencedInPrompt": true,
        "icon": "$(package)",
        "when": "kicadstudio.hasProject",
        "inputSchema": {
          "type": "object",
          "properties": {
            "pcbPath": {
              "type": "string",
              "description": "Optional absolute path to the .kicad_pcb file to export."
            },
            "variant": {
              "type": "string",
              "description": "Optional KiCad 10 variant name to pass to supported kicad-cli exports."
            }
          }
        }
      },
      {
        "name": "kicadstudio_openFile",
        "tags": [
          "kicad",
          "editor"
        ],
        "toolReferenceName": "openFile",
        "displayName": "Open File",
        "userDescription": "Open a local file or URI in the editor.",
        "modelDescription": "Opens a file or URI in VS Code so the user and subsequent tools can inspect it. Use when a chat request needs a specific document opened.",
        "canBeReferencedInPrompt": true,
        "icon": "$(go-to-file)",
        "when": "kicadstudio.hasProject",
        "inputSchema": {
          "type": "object",
          "properties": {
            "uri": {
              "type": "string",
              "description": "Absolute file path or URI to open."
            }
          },
          "required": [
            "uri"
          ]
        }
      },
      {
        "name": "kicadstudio_searchComponent",
        "tags": [
          "kicad",
          "component",
          "search"
        ],
        "toolReferenceName": "searchComponent",
        "displayName": "Search Components",
        "userDescription": "Search online component sources configured in KiCad Studio.",
        "modelDescription": "Searches Octopart/Nexar and LCSC through KiCad Studio and returns matching parts. Use when the user asks for component sourcing or part suggestions.",
        "canBeReferencedInPrompt": true,
        "icon": "$(search)",
        "when": "kicadstudio.hasProject",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Part number, manufacturer part number, value, or descriptive query to search."
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "kicadstudio_searchSymbol",
        "tags": [
          "kicad",
          "symbol",
          "library"
        ],
        "toolReferenceName": "searchSymbol",
        "displayName": "Search Symbols",
        "userDescription": "Search indexed KiCad symbol libraries.",
        "modelDescription": "Searches the local KiCad symbol index and returns matching symbols by name, description, or keyword.",
        "canBeReferencedInPrompt": true,
        "icon": "$(symbol-namespace)",
        "when": "kicadstudio.hasProject",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Symbol name, keyword, or description fragment to search."
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "kicadstudio_searchFootprint",
        "tags": [
          "kicad",
          "footprint",
          "library"
        ],
        "toolReferenceName": "searchFootprint",
        "displayName": "Search Footprints",
        "userDescription": "Search indexed KiCad footprint libraries.",
        "modelDescription": "Searches the local KiCad footprint index and returns matching footprints by name, description, or tags.",
        "canBeReferencedInPrompt": true,
        "icon": "$(circuit-board)",
        "when": "kicadstudio.hasProject",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Footprint name, tag, or description fragment to search."
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "kicadstudio_getActiveContext",
        "tags": [
          "kicad",
          "context"
        ],
        "toolReferenceName": "getActiveContext",
        "displayName": "Get Active KiCad Context",
        "userDescription": "Return the current KiCad Studio editor and diagnostics context.",
        "modelDescription": "Returns the active file, file type, active variant, DRC summary inputs, cursor position, and other live KiCad Studio context. Use when the model needs up-to-date project state before deciding on another tool call.",
        "canBeReferencedInPrompt": true,
        "icon": "$(info)",
        "when": "kicadstudio.hasProject",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "kicadstudio_listVariants",
        "tags": [
          "kicad",
          "variants"
        ],
        "toolReferenceName": "listVariants",
        "displayName": "List KiCad Variants",
        "userDescription": "List the KiCad 10 design variants known to the workspace.",
        "modelDescription": "Returns the available KiCad design variants and override counts. Use when the user asks which variants exist or before switching variants.",
        "canBeReferencedInPrompt": true,
        "icon": "$(list-tree)",
        "when": "kicadstudio.hasVariants",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "kicadstudio_switchVariant",
        "tags": [
          "kicad",
          "variants"
        ],
        "toolReferenceName": "switchVariant",
        "displayName": "Switch KiCad Variant",
        "userDescription": "Change the active KiCad design variant.",
        "modelDescription": "Sets the active KiCad 10 variant in the project file. Use only when the user explicitly wants to switch variants.",
        "canBeReferencedInPrompt": true,
        "icon": "$(git-branch)",
        "when": "kicadstudio.hasVariants",
        "inputSchema": {
          "type": "object",
          "properties": {
            "variant": {
              "type": "string",
              "description": "Exact KiCad variant name to activate."
            }
          },
          "required": [
            "variant"
          ]
        }
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "kicadstudio",
        "displayName": "KiCad Studio",
        "managementCommand": "kicadstudio.manageChatProvider"
      }
    ]
  },
  "scripts": {
    "prepare:media": "node scripts/bundle-kicanvas.js",
    "generate:assets": "node scripts/generate-icon.js",
    "vscode:prepublish": "npm run build:prod",
    "build": "npm run prepare:media && webpack --mode production",
    "build:prod": "npm run build",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src test scripts --ext .ts,.js",
    "audit:ci": "npm audit --audit-level=moderate",
    "compile-tests": "tsc -p tsconfig.test.json",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --runInBand",
    "test:integration": "node ./out/test/runTest.js",
    "test:e2e": "playwright test test/e2e/",
    "check:bundle-size": "node scripts/check-bundle-size.js",
    "bundle-kicanvas": "node scripts/bundle-kicanvas.js",
    "package": "vsce package",
    "package:ls": "vsce ls --tree",
    "publish": "vsce publish",
    "pretest": "npm run build && npm run compile-tests"
  },
  "c8": {
    "reporter": [
      "text",
      "lcov"
    ],
    "all": true,
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.test.ts"
    ],
    "branches": 70,
    "functions": 75,
    "lines": 75
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "c8": "^10.1.3",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "mocha": "^11.7.5",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  },
  "overrides": {
    "mocha": {
      "diff": "^8.0.4",
      "serialize-javascript": "^7.0.5"
    }
  }
}
