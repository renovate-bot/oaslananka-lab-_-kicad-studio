      },
      {
        "command": "kicadstudio.openDesignIntent",
        "title": "KiCad: Open Design Intent",
        "category": "KiCad MCP"
      },
      {
        "command": "kicadstudio.refreshFixQueue",
        "title": "KiCad: Refresh AI Fix Queue",
        "category": "KiCad MCP",
        "icon": "$(refresh)"
      },
      {
        "command": "kicadstudio.applyFixQueueItem",
        "title": "KiCad: Apply AI Fix",
        "category": "KiCad MCP"
      },
      {
        "command": "kicadstudio.variant.create",
        "title": "KiCad: New Variant",
