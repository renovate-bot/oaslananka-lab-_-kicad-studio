        "category": "KiCad Setup"
      },
      {
        "command": "kicadstudio.setAiApiKey",
        "title": "KiCad: Set AI API Key",
        "category": "KiCad Setup"
      },
      {
        "command": "kicadstudio.clearSecrets",
        "title": "KiCad: Clear Stored Secrets",
        "category": "KiCad Setup"
      },
      {
        "command": "kicadstudio.showStoredSecrets",
        "title": "KiCad: Show Stored Secret Keys",
        "category": "KiCad Setup"
      },
      {
        "command": "kicadstudio.manageChatProvider",
        "title": "KiCad: Manage Chat Provider",
        "category": "KiCad AI"
      },
      {
        "command": "kicadstudio.export3DPdf",
        "title": "KiCad: Export 3D PDF",
        "category": "KiCad Export"
      },
      {
        "command": "kicadstudio.setupMcpIntegration",
        "title": "KiCad: Setup MCP Integration",
